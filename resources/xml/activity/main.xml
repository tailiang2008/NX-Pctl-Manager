<?xml version="1.0" encoding="UTF-8"?>

<!--
    Step (a) hello-world layout. Replaced in step (b) with the real main menu
    (status panel + 5 ListItems). For now: title bar + a centred greeting.
-->

<brls:AppletFrame
    title="@i18n/nx_pctl/title"
    iconInterpolation="linear">

    <brls:Box
        width="auto"
        height="auto"
        axis="column"
        justifyContent="center"
        alignItems="center"
        grow="1.0">

        <brls:Label
            text="@i18n/nx_pctl/hello"
            fontSize="32" />

    </brls:Box>

</brls:AppletFrame>
